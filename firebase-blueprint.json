{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "A task in the Kanban board.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the task."
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the task."
        },
        "status": {
          "type": "string",
          "enum": ["todo", "in-progress", "done"],
          "description": "The current status of the task."
        },
        "priority": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "description": "The priority of the task."
        },
        "authorId": {
          "type": "string",
          "description": "The UID of the user who created the task."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the task was created."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the task was last updated."
        }
      },
      "required": ["title", "status", "priority", "authorId", "createdAt", "updatedAt"]
    },
    "User": {
      "title": "User",
      "description": "A user profile.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "The user's role."
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "When the user was created."
        }
      },
      "required": ["name", "email", "role"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for a user.",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "description": "The type of notification."
        },
        "recipient": {
          "type": "string",
          "description": "The user receiving the notification."
        },
        "title": {
          "type": "string",
          "description": "The title of the notification."
        },
        "message": {
          "type": "string",
          "description": "The message body of the notification."
        },
        "task_display_id": {
          "type": "string",
          "description": "The display ID of the associated task."
        },
        "read": {
          "type": "boolean",
          "description": "Whether the notification has been read."
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "When the notification was created."
        }
      },
      "required": ["type", "recipient", "title", "message", "read", "created_at"]
    },
    "DataListLink": {
      "title": "DataListLink",
      "description": "A link in the Data List Link section.",
      "type": "object",
      "properties": {
        "display_id": {
          "type": "string",
          "description": "Optional display ID."
        },
        "category": {
          "type": "string",
          "description": "Category of the link."
        },
        "link_name": {
          "type": "string",
          "description": "Name of the link."
        },
        "link_url": {
          "type": "string",
          "description": "The actual URL."
        },
        "description": {
          "type": "string",
          "description": "Description of the link."
        },
        "note": {
          "type": "string",
          "description": "Any additional note for the link."
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp."
        },
        "updated_at": {
          "type": "string",
          "format": "date-time",
          "description": "Last update timestamp."
        }
      },
      "required": ["category", "link_name", "link_url", "created_at", "updated_at"]
    }
  },
  "firestore": {
    "/tasks/{taskId}": {
      "schema": {
        "$ref": "#/entities/Task"
      },
      "description": "Stores all tasks."
    },
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles."
    },
    "/notifications/{notificationId}": {
      "schema": {
        "$ref": "#/entities/Notification"
      },
      "description": "Stores user notifications."
    },
    "/data_list_link/{linkId}": {
      "schema": {
        "$ref": "#/entities/DataListLink"
      },
      "description": "Stores all data list links."
    }
  }
}
